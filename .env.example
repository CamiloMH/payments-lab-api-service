# Base de datos (MariaDB local vía docker-compose; el host publica 3309 → 3306)
DB_HOST=localhost
DB_PORT=3309
DB_USER=payments
DB_PASSWORD=payments_pass
DB_NAME=payments_lab
DB_ROOT_PASSWORD=rootpass
# Nunca 'true': el esquema lo gobiernan las migraciones.
DB_SYNCHRONIZE=false
DB_LOGGING=false

# API
API_PORT=3001
NODE_ENV=development
PUBLIC_API_URL=http://localhost:3001
# Origen del frontend permitido por CORS y usado para redirigir tras un pago.
# En dev: localhost:3000. En prod: https://payments.camilomunoz.dev
WEB_BASE_URL=http://localhost:3000

# ── Mercado Pago (sandbox) ───────────────────────────────────────────────────
# Obtener en https://www.mercadopago.cl/developers → credenciales de prueba.
MERCADOPAGO_ACCESS_TOKEN=
# Secreto para validar la firma x-signature de los webhooks (opcional en dev).
MERCADOPAGO_WEBHOOK_SECRET=

# ── Stripe (test) ────────────────────────────────────────────────────────────
# Clave secreta de test del dashboard de Stripe (sk_test_…). Checkout Session
# hosted; el retorno se verifica con sessions.retrieve. Montos en CLP (zero-decimal).
STRIPE_SECRET_KEY=

# ── Sentry (observabilidad) ──────────────────────────────────────────────────
# DSN del proyecto Sentry. Si queda vacío, Sentry no se inicializa (dev/test).
SENTRY_DSN=
# Tasa de muestreo de trazas de performance y de profiling (0.0–1.0).
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILES_SAMPLE_RATE=1.0
