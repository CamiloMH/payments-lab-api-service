{
  "name": "payments-lab-api-service",
  "version": "0.1.0",
  "description": "API de payments-lab: tienda demo con integraciones de pago Webpay, Oneclick y Mercado Pago en sandbox.",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "nest start",
    "start:prod": "node dist/src/main",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand",
    "migration:generate": "typeorm migration:generate -d src/database/data-source.ts",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/database/data-source.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/database/data-source.ts",
    "db:seed": "fixtures load ./fixtures --dataSource=./src/database/data-source.ts --require=ts-node/register --require=tsconfig-paths/register",
    "db:seed:fresh": "fixtures load ./fixtures --sync --dataSource=./src/database/data-source.ts --require=ts-node/register --require=tsconfig-paths/register",
    "db:reset": "pnpm migration:revert && pnpm migration:run && pnpm db:seed",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md}\"",
    "release": "bash scripts/release.sh",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@nestjs/common": "^11",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/platform-express": "^11",
    "@nestjs/platform-socket.io": "^11",
    "@nestjs/schedule": "^6.0.0",
    "@nestjs/swagger": "^11",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11",
    "@scalar/nestjs-api-reference": "^1.2.8",
    "@sentry/nestjs": "^10.65.0",
    "@sentry/profiling-node": "^10.65.0",
    "class-transformer": "^0.5.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.7",
    "mercadopago": "^2.9.0",
    "mysql2": "^3.12.0",
    "nanoid": "^3.3.8",
    "nestjs-zod": "^5.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "stripe": "^22.3.1",
    "transbank-sdk": "^6.1.1",
    "typeorm": "^0.3.28",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11",
    "@nestjs/schematics": "^11",
    "@nestjs/testing": "^11",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5",
    "@types/jest": "^29.5.14",
    "@types/node": "^22",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "socket.io-client": "^4.8.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typeorm-fixtures-cli": "^4.1.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
